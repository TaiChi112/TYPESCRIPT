# Backend Environment Variables (Elysia API)

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_db"

# Authentication
JWT_SECRET="CHANGE_THIS_TO_RANDOM_32CHAR_STRING"
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Payment Gateway (Test Mode Only)
# Stripe
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXX

# Omise (Alternative)
# OMISE_SECRET_KEY=skey_test_XXXXXXXXXXXXX
# OMISE_PUBLIC_KEY=pkey_test_XXXXXXXXXXXXX

# Security Notes:
# - Generate JWT_SECRET: openssl rand -base64 32
# - Use test/sandbox keys only for MVP
# - Never commit real secrets to Git
