# Use Bun's official image as the base
FROM oven/bun:1 AS base

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json ./

# Install dependencies
RUN bun install --frozen-lockfile

# Development stage
FROM base AS development
# Copy source code
COPY src ./src

# Expose port
EXPOSE 3000

# Command for development
CMD ["bun", "run", "dev"]

# Production stage
FROM base AS production
# Copy source code
COPY src ./src

# Build the application (if you have a build script)
RUN bun run build

# Expose port
EXPOSE 3000

# Command for production
CMD ["bun", "run", "start"]
